# CodeCompanion — environment template
# Copy to .env.local and fill in. Keep mock-first defaults until the COMPLIANCE.md gate is closed.

# ---- Compliance master switch -------------------------------------------
# Stays false until BAAs are signed, RLS is enforced, audit logging is live,
# and de-id gate tests pass. See COMPLIANCE.md and GO-LIVE.md (npm run readiness).
ALLOW_REAL_PHI=false
ALLOW_REAL_CHARGES=false             # gates real Stripe card charges
# Go-live acknowledgements — set by a human once truly done (see GO-LIVE.md):
BAA_SIGNED=false
HIPAA_SECURITY_REVIEW=false

# ---- Adapter mock flags --------------------------------------------------
ATHENA_USE_MOCK=true
EDI_USE_SAMPLE_FILES=true

# Real EDI files — only read when EDI_USE_SAMPLE_FILES=false AND ALLOW_REAL_PHI=true
# EDI_837_PATH=
# EDI_835_PATH=
# FEE_SCHEDULE_PATH=

# ---- Clearinghouse (Stedi: eligibility 270/271 + claim submission 837/835) ----
# Sandbox is safe with synthetic data (no BAA needed). Production transmits
# real PHI to payers and requires ALLOW_REAL_PHI=true (+ payer enrollment for
# claims/ERA; eligibility usually needs no enrollment). Defaults to sandbox;
# never auto-uses production. Same STEDI_API_KEY drives eligibility and claims.
# CLEARINGHOUSE_PROVIDER=mock         # mock | stedi
# STEDI_API_KEY=
# STEDI_SANDBOX=true
# STEDI_BASE_URL=
# STEDI_TEST_PAYER_ID=STEDITEST     # Stedi Test Payer id for sandbox claim trials
# STEDI_SUBMITTER_ID=               # submitter identification (defaults to billing tax id)
# STEDI_ELIGIBILITY_PATH=           # override the 270/271 endpoint path (optional)
# STEDI_ELIGIBILITY_API_KEY=        # OPTIONAL separate key for eligibility — use a
#   Stedi TEST key here (so the documented mock members return active coverage)
#   while STEDI_API_KEY stays your production key for claims. Falls back to
#   STEDI_API_KEY when unset.

# ---- Supabase ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-side only; never ship to client

# ---- Auth — Supabase Auth (settled; uses the Supabase URL + anon key above) ----
# Clerk is not used.

# ---- Anthropic (language tasks only: appeals, narratives, coding suggestions)
ANTHROPIC_API_KEY=

# ---- Stripe (SaaS + contingency billing) ---------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Athena (real integration — only used when ATHENA_USE_MOCK=false AND ALLOW_REAL_PHI=true) ----
# Pull clinical encounters + charges from athenahealth into the canonical model;
# CodeCompanion's own rails (Stedi) still do eligibility/claims. Needs a BAA.
# ATHENA_CLIENT_ID=
# ATHENA_CLIENT_SECRET=
# ATHENA_PRACTICE_ID=
# ATHENA_BASE_URL=                  # https://api.preview.platform.athenahealth.com (sandbox) | https://api.platform.athenahealth.com (prod)
